generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  owner
  office
  school
}

enum SchoolLevel {
  tk_kb
  sd
  smp
  sma_smk
}

enum EmployeeType {
  guru
  pegawai
}

enum FacilityCondition {
  baik
  rusak_ringan
  rusak_berat
}

enum FinanceType {
  spp
  dpp
  bos
  bosda
  rekening
  lain_lain
}

model Contact {
  id       String  @id @default(cuid())
  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  name     String
  email    String?
  message  String  @db.Text

  createdAt DateTime @default(now())

  @@map("contacts")
}

model Document {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name      String
  fileUrl   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("documents")
}

model Employee {
  id             String       @id @default(cuid())
  name           String
  birthPlaceDate String?
  birthDate      DateTime?
  religion       String?
  address        String?      @db.Text
  type           EmployeeType @default(guru)
  schoolId       String
  school         School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  position       String?
  otherPosition  String?
  status         String?
  gender         String?
  joinDate       DateTime?
  lastEducation  String?
  phone          String?
  email          String?
  decreeNumber   String?
  fee            String?
  photoUrl       String?
  decreeUrl      String?
  workingPeriod  String?
  retirementAge  Int?
  retirementDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("employees")
}

model Facility {
  id        String            @id @default(cuid())
  schoolId  String
  school    School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name      String
  quantity  Int               @default(0)
  condition FacilityCondition

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("facilities")
}

model Finance {
  id        String      @id @default(cuid())
  schoolId  String
  school    School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  type      FinanceType
  className String?
  amount    Int?
  accountNo String?
  balance   Int?
  date      DateTime?
  note      String?     @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("finances")
}

model School {
  id        String      @id @default(cuid())
  name      String
  level     SchoolLevel
  address   String?
  phone     String?
  email     String?
  principal String?
  canEdit   Boolean     @default(false)

  users      User[]
  profile    SchoolProfile?
  employees  Employee[]
  students   Student[]
  assets     SchoolAsset[]
  facilities Facility[]
  finances   Finance[]
  documents  Document[]
  contacts   Contact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("schools")
}

model SchoolAsset {
  id               String  @id @default(cuid())
  schoolId         String
  school           School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  landArea         String?
  certificateOwner String?
  origin           String?
  procurementYear  Int?
  buildingArea     String?
  photoUrl         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("school_assets")
}

model SchoolProfile {
  id       String  @id @default(cuid())
  schoolId String  @unique
  school   School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  history  String? @db.Text
  vision   String? @db.Text
  mission  String? @db.Text
  motto    String?
  photoUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("school_profiles")
}

model Student {
  id             String  @id @default(cuid())
  schoolId       String
  school         School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name           String
  birthPlaceDate String?
  address        String? @db.Text
  gender         String?
  religion       String?
  fatherName     String?
  motherName     String?
  fatherJob      String?
  motherJob      String?
  className      String?
  sppAmount      Int?
  photoUrl       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("students")
}

model User {
  id                  String    @id @default(cuid())
  name                String
  email               String    @unique
  password            String
  role                Role
  schoolId            String?
  school              School?   @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  activeSessionId     String?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@map("users")
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  entity      String
  entityId    String?
  description String   @db.Text
  userId      String?
  userEmail   String?
  userRole    Role?
  schoolId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([schoolId])
  @@index([userId])
  @@index([entity])
  @@map("audit_logs")
}
